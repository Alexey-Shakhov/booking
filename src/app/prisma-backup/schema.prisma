generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Room {
  id        Int      @id @default(autoincrement())
  name      String
  capacity  Int
  features  String[] // PostgreSQL array
  bookings  Booking[]
  
  @@map("rooms")
}

model Booking {
  id           Int      @id @default(autoincrement())
  resourceType String
  resourceId   Int
  title        String
  startUtc     DateTime
  endUtc       DateTime
  notes        String?
  room         Room     @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  
  @@index([resourceId])
  @@map("bookings")
}
